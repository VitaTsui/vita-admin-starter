NODE_ENV=development
SERVER_PROT=3003
API_BASE="/api"
API_PROXY=`{
  "/api/": {
    "target": "http://localhost:8383",
    "pathRewrite": {
      "^/api": ""
    }
  }
}`
DEFAULT_PATH="/"

# 登录加密用，需与后端的加密配置一一对应。请替换为你自己的密钥。
CRYPTO_KEY="ReplaceWithYourAES256SecretKey__"
RSA_PUB_KEY="ReplaceWithYourRSAPublicKeyBase64"
